<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= entry.title %> - Wiki - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="row">
      <!-- 左侧内容 -->
      <div class="col-lg-9">
        <div class="card">
          <div class="card-body wiki-content">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <span class="badge bg-info text-white mb-2"><%= entry.category || '其他' %></span>
                <h1 class="h2"><%= entry.title %></h1>
              </div>
            </div>

            <div class="text-muted small mb-4">
              <i class="bi bi-person"></i> 由 <%= entry.username %> 编辑
              <span class="mx-2">|</span>
              <i class="bi bi-clock"></i> 最后更新 <%= new Date(entry.updated_at).toLocaleString() %>
            </div>

            <div class="content-body">
              <%- entry.contentHtml %>
            </div>
          </div>
        </div>
      </div>

      <!-- 右侧边栏 -->
      <div class="col-lg-3">
        <div class="card wiki-toc">
          <div class="card-header">
            <i class="bi bi-list"></i> 目录
          </div>
          <div class="card-body">
            <p class="text-muted small">目录功能开发中...</p>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">相关词条</div>
          <div class="card-body">
            <p class="text-muted small">功能开发中...</p>
          </div>
        </div>

        <% if (typeof user !== 'undefined' && user) { %>
          <div class="card mt-3">
            <div class="card-body text-center">
              <a href="/wiki/new" class="btn btn-outline-info w-100">
                <i class="bi bi-pencil"></i> 编辑词条
              </a>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
