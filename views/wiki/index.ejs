<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Agent Wiki - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2><i class="bi bi-book text-info"></i> AI Agent Wiki</h2>
        <p class="text-muted mb-0">AI Agent名词解释和知识库，共建共享</p>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/wiki/new" class="btn btn-info text-white">
          <i class="bi bi-plus-lg"></i> 新建词条
        </a>
      <% } %>
    </div>

    <!-- Wiki分类 -->
    <div class="row">
      <div class="col-md-3">
        <div class="card wiki-toc">
          <div class="card-header">分类</div>
          <div class="list-group list-group-flush">
            <a href="/wiki" class="list-group-item list-group-item-action active">全部</a>
            <a href="/wiki?category=concept" class="list-group-item list-group-item-action">基础概念</a>
            <a href="/wiki?category=tool" class="list-group-item list-group-item-action">工具/平台</a>
            <a href="/wiki?category=technique" class="list-group-item list-group-item-action">技术方法</a>
            <a href="/wiki?category=case" class="list-group-item list-group-item-action">案例实践</a>
          </div>
        </div>
      </div>

      <div class="col-md-9">
        <div class="card">
          <div class="card-header">
            词条列表
          </div>
          <div class="card-body">
            <% if (entries && entries.length > 0) { %>
              <div class="list-group list-group-flush">
                <% entries.forEach(entry => { %>
                  <a href="/wiki/<%= entry.slug %>" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                      <h5 class="mb-1"><%= entry.title %></h5>
                      <span class="badge bg-secondary"><%= entry.category || '其他' %></span>
                    </div>
                    <p class="mb-1 text-muted small">
                      <%= entry.content ? entry.content.substring(0, 100) + '...' : '' %>
                    </p>
                    <small class="text-muted">编辑于 <%= new Date(entry.updated_at).toLocaleDateString() %></small>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="text-center py-5">
                <i class="bi bi-book display-1 text-muted"></i>
                <p class="mt-3 text-muted">暂无词条</p>
                <% if (typeof user !== 'undefined' && user) { %>
                  <a href="/wiki/new" class="btn btn-info text-white">创建第一个词条</a>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
