<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= user.username %> - 个人主页</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container my-5">
    <div class="row">
      <!-- 左侧个人信息 -->
      <div class="col-md-3">
        <div class="card text-center">
          <div class="card-body">
            <div class="mb-3">
              <i class="bi bi-person-circle display-1 text-primary"></i>
            </div>
            <h4><%= user.username %></h4>
            <p class="text-muted small"><%= user.email %></p>
            <p class="text-muted"><%= user.bio || '这个人很懒，还没有写简介...' %></p>
            <hr>
            <div class="row text-center">
              <div class="col-4">
                <h5><%= user.followers || 0 %></h5>
                <small class="text-muted">粉丝</small>
              </div>
              <div class="col-4">
                <h5><%= user.following || 0 %></h5>
                <small class="text-muted">关注</small>
              </div>
              <div class="col-4">
                <h5><%= (skills ? skills.length : 0) + (posts ? posts.length : 0) + (questions ? questions.length : 0) %></h5>
                <small class="text-muted">发布</small>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <h6 class="card-title">快速操作</h6>
            <div class="list-group list-group-flush">
              <a href="/skills/new" class="list-group-item list-group-item-action">
                <i class="bi bi-plus-circle text-primary"></i> 发布技能
              </a>
              <a href="/questions/new" class="list-group-item list-group-item-action">
                <i class="bi bi-question-circle text-danger"></i> 提问
              </a>
              <a href="/posts/new" class="list-group-item list-group-item-action">
                <i class="bi bi-file-text text-success"></i> 发布创意
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- 右侧内容 -->
      <div class="col-md-9">
        <!-- 我的技能 -->
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-code-square text-primary"></i> 我的技能</h5>
            <a href="/skills/new" class="btn btn-sm btn-primary">+ 发布</a>
          </div>
          <div class="card-body">
            <% if (skills && skills.length > 0) { %>
              <div class="row">
                <% skills.forEach(skill => { %>
                  <div class="col-md-6 mb-3">
                    <div class="card skill-card h-100">
                      <div class="card-body">
                        <h6><a href="/skills/<%= skill.id %>"><%= skill.title %></a></h6>
                        <p class="small text-muted mb-2"><%= skill.description ? skill.description.substring(0, 50) + '...' : '' %></p>
                        <div class="text-muted small">
                          <i class="bi bi-heart"></i> <%= skill.likes %>
                          <i class="bi bi-bookmark ms-2"></i> <%= skill.favorites %>
                          <span class="ms-2"><%= new Date(skill.created_at).toLocaleDateString() %></span>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">还没有发布技能 <a href="/skills/new">立即发布</a></p>
            <% } %>
          </div>
        </div>

        <!-- 我的帖子 -->
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-file-text text-success"></i> 我的创意</h5>
            <a href="/posts/new" class="btn btn-sm btn-success">+ 发布</a>
          </div>
          <div class="card-body">
            <% if (posts && posts.length > 0) { %>
              <div class="list-group list-group-flush">
                <% posts.forEach(post => { %>
                  <a href="/posts/<%= post.id %>" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between">
                      <h6 class="mb-1"><%= post.title %></h6>
                      <small class="text-muted"><%= new Date(post.created_at).toLocaleDateString() %></small>
                    </div>
                    <p class="mb-1 small text-muted"><%= post.content ? post.content.substring(0, 100) + '...' : '' %></p>
                    <small class="text-muted">
                      <i class="bi bi-eye"></i> <%= post.views %>
                      <i class="bi bi-heart ms-2"></i> <%= post.likes %>
                    </small>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">还没有发布创意 <a href="/posts/new">立即分享</a></p>
            <% } %>
          </div>
        </div>

        <!-- 我的问题 -->
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-question-circle text-danger"></i> 我的问题</h5>
            <a href="/questions/new" class="btn btn-sm btn-danger">+ 提问</a>
          </div>
          <div class="card-body">
            <% if (questions && questions.length > 0) { %>
              <div class="list-group list-group-flush">
                <% questions.forEach(q => { %>
                  <a href="/questions/<%= q.id %>" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between">
                      <h6 class="mb-1"><%= q.title %></h6>
                      <small class="text-muted"><%= new Date(q.created_at).toLocaleDateString() %></small>
                    </div>
                    <small class="text-muted">
                      <i class="bi bi-eye"></i> <%= q.views %>
                      <i class="bi bi-heart ms-2"></i> <%= q.likes %>
                    </small>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">还没有提问 <a href="/questions/new">立即提问</a></p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
