<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= user.username %> - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container my-5">
    <div class="row">
      <!-- 左侧信息 -->
      <div class="col-md-3">
        <div class="card text-center">
          <div class="card-body">
            <i class="bi bi-person-circle display-1 text-primary"></i>
            <h4 class="mt-3"><%= user.username %></h4>
            <p class="text-muted small"><%= user.bio || '这个人很懒，还没有写简介...' %></p>
            
            <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.id !== user.id) { %>
              <button class="btn btn-primary btn-sm" onclick="followUser(<%= user.id %>)">
                <i class="bi bi-plus"></i> 关注
              </button>
            <% } %>
            
            <hr>
            <div class="row text-center">
              <div class="col-6">
                <h5><%= user.followers || 0 %></h5>
                <small class="text-muted">粉丝</small>
              </div>
              <div class="col-6">
                <h5><%= user.following || 0 %></h5>
                <small class="text-muted">关注</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 右侧内容 -->
      <div class="col-md-9">
        <!-- 发布的技能 -->
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-code-square text-primary"></i> 发布的技能</h5>
          </div>
          <div class="card-body">
            <% if (skills && skills.length > 0) { %>
              <div class="row">
                <% skills.forEach(skill => { %>
                  <div class="col-md-6 mb-3">
                    <div class="card skill-card h-100">
                      <div class="card-body">
                        <h6><a href="/skills/<%= skill.id %>"><%= skill.title %></a></h6>
                        <p class="small text-muted"><%= skill.description ? skill.description.substring(0, 50) + '...' : '' %></p>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">暂无技能</p>
            <% } %>
          </div>
        </div>

        <!-- 发布的帖子 -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-file-text text-success"></i> 创意分享</h5>
          </div>
          <div class="card-body">
            <% if (posts && posts.length > 0) { %>
              <div class="list-group list-group-flush">
                <% posts.forEach(post => { %>
                  <a href="/posts/<%= post.id %>" class="list-group-item list-group-item-action">
                    <h6><%= post.title %></h6>
                    <small class="text-muted"><%= new Date(post.created_at).toLocaleDateString() %></small>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">暂无分享</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
