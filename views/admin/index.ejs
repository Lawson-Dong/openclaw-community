<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid my-4">
    <div class="row">
      <!-- 侧边栏 -->
      <div class="col-md-2">
        <div class="card admin-sidebar">
          <div class="card-header bg-dark text-white">
            <i class="bi bi-shield"></i> 管理菜单
          </div>
          <div class="list-group list-group-flush">
            <a href="/admin" class="list-group-item list-group-item-action active">
              <i class="bi bi-speedometer2"></i> 仪表盘
            </a>
            <a href="/admin/users" class="list-group-item list-group-item-action">
              <i class="bi bi-people"></i> 用户管理
            </a>
            <a href="/admin/skills" class="list-group-item list-group-item-action">
              <i class="bi bi-code-square"></i> 技能审核
            </a>
            <a href="/admin/wiki" class="list-group-item list-group-item-action">
              <i class="bi bi-book"></i> Wiki审核
            </a>
          </div>
        </div>
      </div>

      <!-- 主内容区 -->
      <div class="col-md-10">
        <h2 class="mb-4"><i class="bi bi-speedometer2"></i> 管理仪表盘</h2>

        <!-- 统计卡片 -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card bg-primary text-white">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-code-square"></i> 技能</h5>
                <p class="h3"><%= skills ? skills.length : 0 %></p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-danger text-white">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-question-circle"></i> 问题</h5>
                <p class="h3"><%= questions ? questions.length : 0 %></p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-success text-white">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-file-text"></i> 帖子</h5>
                <p class="h3"><%= posts ? posts.length : 0 %></p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-info text-white">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-book"></i> Wiki待审</h5>
                <p class="h3"><%= pendingWiki ? pendingWiki.length : 0 %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- 待审核Wiki -->
        <div class="card mb-4">
          <div class="card-header bg-warning text-dark">
            <i class="bi bi-clock"></i> 待审核Wiki词条
          </div>
          <div class="card-body">
            <% if (pendingWiki && pendingWiki.length > 0) { %>
              <div class="table-responsive">
                <table class="table">
                  <thead>
                    <tr>
                      <th>词条</th>
                      <th>分类</th>
                      <th>提交者</th>
                      <th>提交时间</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% pendingWiki.forEach(wiki => { %>
                      <tr>
                        <td><%= wiki.title %></td>
                        <td><%= wiki.category %></td>
                        <td><%= wiki.username %></td>
                        <td><%= new Date(wiki.created_at).toLocaleString() %></td>
                        <td>
                          <button class="btn btn-sm btn-success" onclick="approveWiki(<%= wiki.id %>)">通过</button>
                          <button class="btn btn-sm btn-danger" onclick="deleteItem('wiki', <%= wiki.id %>)">删除</button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center mb-0">暂无待审核词条</p>
            <% } %>
          </div>
        </div>

        <!-- 最新内容 -->
        <div class="row">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">最新技能</div>
              <div class="list-group list-group-flush">
                <% if (skills && skills.length > 0) { %>
                  <% skills.slice(0, 5).forEach(skill => { %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <a href="/skills/<%= skill.id %>" target="_blank"><%= skill.title %></a>
                        <small class="text-muted d-block">by <%= skill.username %></small>
                      </div>
                      <button class="btn btn-sm btn-outline-danger" onclick="deleteItem('skill', <%= skill.id %>)">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">最新问题</div>
              <div class="list-group list-group-flush">
                <% if (questions && questions.length > 0) { %>
                  <% questions.slice(0, 5).forEach(q => { %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <a href="/questions/<%= q.id %>" target="_blank"><%= q.title %></a>
                        <small class="text-muted d-block">by <%= q.username %></small>
                      </div>
                      <button class="btn btn-sm btn-outline-danger" onclick="deleteItem('question', <%= q.id %>)">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    async function deleteItem(type, id) {
      if (!confirm('确定要删除吗？')) return;
      const res = await fetch(`/admin/delete/${type}/${id}`, { method: 'POST' });
      if (res.ok) location.reload();
    }

    async function approveWiki(id) {
      const res = await fetch(`/admin/wiki/${id}/approve`, { method: 'POST' });
      if (res.ok) location.reload();
    }
  </script>
</body>
</html>
