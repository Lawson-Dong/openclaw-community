<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>技能目录 - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2><i class="bi bi-code-square text-primary"></i> 技能目录</h2>
        <p class="text-muted mb-0">发现和分享OpenClaw技能</p>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/skills/new" class="btn btn-primary">
          <i class="bi bi-plus-lg"></i> 发布技能
        </a>
      <% } %>
    </div>

    <!-- 筛选栏 -->
    <div class="card mb-4">
      <div class="card-body">
        <form class="row g-3" method="GET" action="/skills">
          <div class="col-md-4">
            <input type="text" name="search" class="form-control" placeholder="搜索技能..." value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>">
          </div>
          <div class="col-md-3">
            <select name="category" class="form-select">
              <option value="">所有分类</option>
              <option value="web-automation" <%= typeof filters !== 'undefined' && filters.category === 'web-automation' ? 'selected' : '' %>>网页自动化</option>
              <option value="data-scraping" <%= typeof filters !== 'undefined' && filters.category === 'data-scraping' ? 'selected' : '' %>>数据抓取</option>
              <option value="office" <%= typeof filters !== 'undefined' && filters.category === 'office' ? 'selected' : '' %>>办公自动化</option>
              <option value="trading" <%= typeof filters !== 'undefined' && filters.category === 'trading' ? 'selected' : '' %>>交易/金融</option>
              <option value="content" <%= typeof filters !== 'undefined' && filters.category === 'content' ? 'selected' : '' %>>内容创作</option>
              <option value="other" <%= typeof filters !== 'undefined' && filters.category === 'other' ? 'selected' : '' %>>其他</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">
              <i class="bi bi-search"></i> 筛选
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- 技能列表 -->
    <div class="row">
      <% if (skills && skills.length > 0) { %>
        <% skills.forEach(skill => { %>
          <div class="col-md-4 mb-4">
            <div class="card h-100 skill-card">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <span class="badge bg-primary"><%= skill.category || '未分类' %></span>
                  <span class="text-warning">
                    <i class="bi bi-star-fill"></i> <%= skill.rating || 0 %>
                  </span>
                </div>
                <h5 class="card-title">
                  <a href="/skills/<%= skill.id %>" class="text-decoration-none"><%= skill.title %></a>
                </h5>
                <p class="card-text text-muted small"><%= skill.description ? skill.description.substring(0, 100) + '...' : '暂无描述' %></p>
                <div class="mt-3">
                  <% if (skill.tags) { %>
                    <% skill.tags.split(',').slice(0, 3).forEach(tag => { %>
                      <span class="badge bg-light text-dark me-1"><%= tag.trim() %></span>
                    <% }) %>
                  <% } %>
                </div>
              </div>
              <div class="card-footer bg-transparent">
                <div class="d-flex justify-content-between align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-person-circle me-1 text-muted"></i>
                    <small class="text-muted"><%= skill.username %></small>
                  </div>
                  <div class="text-muted small">
                    <i class="bi bi-heart"></i> <%= skill.likes %>
                    <i class="bi bi-bookmark ms-2"></i> <%= skill.favorites %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <i class="bi bi-inbox display-1 text-muted"></i>
          <p class="mt-3 text-muted">暂无技能</p>
          <% if (typeof user !== 'undefined' && user) { %>
            <a href="/skills/new" class="btn btn-primary">发布第一个技能</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
