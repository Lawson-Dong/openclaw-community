<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>问题求助 - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2><i class="bi bi-question-circle text-danger"></i> 问题求助</h2>
        <p class="text-muted mb-0">遇到问题？社区帮你解决</p>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/questions/new" class="btn btn-danger">
          <i class="bi bi-plus-lg"></i> 提问
        </a>
      <% } %>
    </div>

    <!-- 排序选项 -->
    <div class="card mb-4">
      <div class="card-body">
        <div class="btn-group">
          <a href="/questions?sort=newest" class="btn btn-outline-secondary <%= typeof sort !== 'undefined' && sort === 'newest' ? 'active' : '' %>">
            <i class="bi bi-clock"></i> 最新
          </a>
          <a href="/questions?sort=hot" class="btn btn-outline-secondary <%= typeof sort !== 'undefined' && sort === 'hot' ? 'active' : '' %>">
            <i class="bi bi-fire"></i> 最热
          </a>
        </div>
      </div>
    </div>

    <!-- 问题列表 -->
    <div class="card">
      <div class="list-group list-group-flush">
        <% if (questions && questions.length > 0) { %>
          <% questions.forEach(q => { %>
            <a href="/questions/<%= q.id %>" class="list-group-item list-group-item-action py-3">
              <div class="d-flex w-100 justify-content-between align-items-start">
                <div class="flex-grow-1">
                  <h5 class="mb-1"><%= q.title %></h5>
                  <p class="mb-1 text-muted small"><%= q.content ? q.content.substring(0, 150) + '...' : '' %></p>
                  <div class="d-flex align-items-center text-muted small">
                    <span class="me-3"><i class="bi bi-person"></i> <%= q.username %></span>
                    <span class="me-3"><i class="bi bi-eye"></i> <%= q.views %> 浏览</span>
                    <span class="me-3"><i class="bi bi-heart"></i> <%= q.likes %></span>
                    <% if (q.tags) { %>
                      <% q.tags.split(',').slice(0, 3).forEach(tag => { %>
                        <span class="badge bg-light text-dark me-1"><%= tag.trim() %></span>
                      <% }) %>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted"><%= new Date(q.created_at).toLocaleDateString() %></small>
              </div>
            </a>
          <% }) %>
        <% } else { %>
          <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="mt-3 text-muted">暂无问题</p>
            <% if (typeof user !== 'undefined' && user) { %>
              <a href="/questions/new" class="btn btn-danger">提出第一个问题</a>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
