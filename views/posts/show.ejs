<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> - OpenClaw Community</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="row">
      <!-- 左侧内容 -->
      <div class="col-lg-8">
        <!-- 帖子主体 -->
        <div class="card mb-4">
          <div class="card-body">
            <h1 class="h3 mb-3"><%= post.title %></h1>

            <div class="d-flex align-items-center mb-3">
              <i class="bi bi-person-circle fs-4 me-2 text-muted"></i>
              <div>
                <a href="/user/<%= post.user_id %>" class="text-decoration-none fw-bold"><%= post.username %></a>
                <div class="text-muted small">发布于 <%= new Date(post.created_at).toLocaleString() %> · <%= post.views %> 浏览</div>
              </div>
            </div>

            <!-- 图片展示 -->
            <% if (post.images) { %>
              <div class="row mb-4">
                <% post.images.split(',').forEach(img => { %>
                  <div class="col-md-4 mb-3">
                    <img src="/uploads/<%= img %>" class="img-fluid rounded" alt="配图">
                  </div>
                <% }) %>
              </div>
            <% } %>

            <div class="content-body mb-3">
              <%- post.contentHtml %>
            </div>

            <div class="d-flex gap-2">
              <% if (typeof user !== 'undefined' && user) { %>
                <button class="btn btn-outline-danger" onclick="likeItem('post', <%= post.id %>)">
                  <i class="bi bi-heart"></i> 喜欢 (<%= post.likes %>)
                </button>
                <button class="btn btn-outline-primary" onclick="favoriteItem('post', <%= post.id %>)">
                  <i class="bi bi-bookmark"></i> 收藏 (<%= post.favorites %>)
                </button>
              <% } else { %>
                <a href="/login" class="btn btn-outline-danger">
                  <i class="bi bi-heart"></i> 喜欢 (<%= post.likes %>)
                </a>
                <a href="/login" class="btn btn-outline-primary">
                  <i class="bi bi-bookmark"></i> 收藏 (<%= post.favorites %>)
                </a>
              <% } %>
            </div>
          </div>
        </div>

        <!-- 评论区 -->
        <div class="card">
          <div class="card-header">
            <i class="bi bi-chat-dots"></i> 评论 (<%= comments ? comments.length : 0 %>)
          </div>
          <div class="card-body">
            <% if (typeof user !== 'undefined' && user) { %>
              <form id="commentForm" class="mb-4">
                <div class="mb-3">
                  <textarea class="form-control" id="commentContent" rows="3" placeholder="写下你的评论..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary">发表评论</button>
              </form>
            <% } else { %>
              <div class="alert alert-info">
                <a href="/login">登录</a> 后发表评论
              </div>
            <% } %>

            <div id="commentsList">
              <% if (comments && comments.length > 0) { %>
                <% comments.forEach(comment => { %>
                  <div class="comment-item">
                    <div class="d-flex">
                      <i class="bi bi-person-circle fs-4 me-2 text-muted"></i>
                      <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                          <a href="/user/<%= comment.user_id %>" class="fw-bold text-decoration-none"><%= comment.username %></a>
                          <small class="text-muted"><%= new Date(comment.created_at).toLocaleString() %></small>
                        </div>
                        <p class="mb-1"><%= comment.content %></p>
                        <div>
                          <button class="btn btn-sm btn-link text-muted" onclick="likeItem('comment', <%= comment.id %>)">
                            <i class="bi bi-hand-thumbs-up"></i> <%= comment.likes %>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-muted text-center py-3">暂无评论</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- 右侧边栏 -->
      <div class="col-lg-4">
        <div class="card mb-3">
          <div class="card-body text-center">
            <i class="bi bi-person-circle display-4 text-muted"></i>
            <h5 class="mt-2"><%= post.username %></h5>
            <a href="/user/<%= post.user_id %>" class="btn btn-outline-primary btn-sm">查看主页</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    document.getElementById('commentForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const content = document.getElementById('commentContent').value;
      if (!content.trim()) return;

      const res = await fetch('/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ target_type: 'post', target_id: <%= post.id %>, content })
      });

      if (res.ok) {
        location.reload();
      }
    });
  </script>
</body>
</html>
